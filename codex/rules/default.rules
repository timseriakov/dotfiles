prefix_rule(pattern=["git", "add", "config.py", "docs/keybindings.md"], decision="allow")
prefix_rule(pattern=["git", "add", "-A"], decision="allow")
prefix_rule(pattern=["ps"], decision="allow")
prefix_rule(pattern=["lsof"], decision="allow")
prefix_rule(pattern=["curl", "-s", "https://api.github.com/repos/smart-mcp-proxy/mcpproxy-go/releases/latest"], decision="allow")
prefix_rule(pattern=["brew", "upgrade", "smart-mcp-proxy/mcpproxy/mcpproxy"], decision="allow")
prefix_rule(pattern=["brew", "info", "smart-mcp-proxy/mcpproxy/mcpproxy"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "HOMEBREW_NO_AUTO_UPDATE=1 brew upgrade smart-mcp-proxy/mcpproxy/mcpproxy"], decision="allow")
prefix_rule(pattern=["mcpproxy", "--version"], decision="allow")
prefix_rule(pattern=["bash", "mcpproxy/launchd-control.sh", "status"], decision="allow")
prefix_rule(pattern=["bash", "mcpproxy/launchd-control.sh", "restart"], decision="allow")
prefix_rule(pattern=["bash", "mcpproxy/launchd-control.sh", "stop"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "killall mcpproxy mcpproxy-tray 2>/dev/null || true; sleep 1; pgrep -af \"mcpproxy|mcpproxy-tray\" || true"], decision="allow")
prefix_rule(pattern=["bash", "mcpproxy/launchd-control.sh", "start"], decision="allow")
