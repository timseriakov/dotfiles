{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
    },
    "librarian": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["google/gemini-2.5-flash"],
    },
    "explore": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["google/gemini-2.5-flash"],
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "medium",
    },
    "sisyphus-junior": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["google/gemini-2.5-flash"],
    },
    "multimodal-looker": {
      "model": "google/gemini-3.1-pro-preview",
      "fallback_models": ["google/gemini-2.5-pro"],
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
    },
    "OpenCode-Builder": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "medium",
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
    },
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true,
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100,
  },
  "background_task": {
    "defaultConcurrency": 6,
    "providerConcurrency": {
      "openai": 4,
      "google": 6,
    },
    "modelConcurrency": {
      "openai/gpt-5.4": 3,
      "openai/gpt-5.4-mini": 6,
      "openai/gpt-5.3-codex": 2,
      "google/gemini-3.1-pro-preview": 3,
      "google/gemini-3-flash-preview": 6,
      "google/gemini-2.5-pro": 3,
      "google/gemini-2.5-flash": 6,
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "fallback_models": ["google/gemini-2.5-pro"],
      "prompt_append": "Focus on modern aesthetics, responsiveness, and clean CSS/Tailwind.",
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "prompt_append": "For architecture tasks, use $likec4-architecture. Prefer LikeC4 DSL changes, validate with `npx likec4 validate`, and return preview/build/export commands.",
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "prompt_append": "Focus on robustness, error handling, and type safety.",
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
    },
    "unspecified-low": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["google/gemini-2.5-flash"],
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
    },
    "writing": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["google/gemini-2.5-flash"],
    },
  },
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": true,
    "agents": true,
    "hooks": true,
    "plugins": true,
    "plugins_override": {},
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": true,
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": false,
      "notification": "off",
      "turn_protection": {
        "enabled": true,
        "turns": 3,
      },
    },
  },
  "disabled_mcps": [],
  "disabled_skills": ["playwright"],
  "disabled_agents": [],
  "disabled_hooks": [],
  "google_auth": false,
  "lsp": {},
}
