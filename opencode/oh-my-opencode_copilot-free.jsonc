{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
    },
    "atlas": {
      "model": "github-copilot/gpt-5-mini",
      "temperature": 0.1,
    },
    "oracle": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
    },
    "librarian": {
      "model": "github-copilot/claude-haiku-4.5",
      "temperature": 0.2,
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "temperature": 0.1,
    },
    "hephaestus": {
      "model": "github-copilot/gpt-4o",
      "variant": "medium",
      "temperature": 0.1,
    },
    "sisyphus-junior": {
      "model": "github-copilot/gpt-5-mini",
      "temperature": 0.1,
    },
    "multimodal-looker": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
    },
    "plan": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.2,
    },
    "OpenCode-Builder": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.05,
    },
    "prometheus": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.2,
    },
    "metis": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.3,
    },
    "momus": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
    },
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true,
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100,
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "copilot": 5,
    },
    "modelConcurrency": {
      "github-copilot/gpt-4o": 3,
      "github-copilot/gpt-5-mini": 3,
      "github-copilot/claude-haiku-4.5": 5,
      "github-copilot/grok-code-fast-1": 8,
      "github-copilot/gpt-4.1": 3,
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.7,
      "prompt_append": "Focus on modern aesthetics, responsiveness, and clean CSS/Tailwind.",
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.15,
      "prompt_append": "For architecture tasks, use $likec4-architecture. Prefer LikeC4 DSL changes, validate with `npx likec4 validate`, and return preview/build/export commands.",
    },
    "deep": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
      "prompt_append": "Focus on robustness, error handling, and type safety.",
    },
    "quick": {
      "model": "github-copilot/gpt-5-mini",
      "temperature": 0.3,
    },
    "unspecified-low": {
      "model": "github-copilot/gpt-5-mini",
      "temperature": 0.3,
    },
    "unspecified-high": {
      "model": "github-copilot/gpt-4o",
      "temperature": 0.1,
    },
    "writing": {
      "model": "github-copilot/gpt-5-mini",
      "temperature": 0.3,
    },
  },
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": true,
    "agents": true,
    "hooks": true,
    "plugins": true,
    "plugins_override": {},
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": true,
    "dynamic_context_pruning": {
      "enabled": false,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3,
      },
    },
  },
  "disabled_mcps": [],
  "disabled_skills": ["playwright"],
  "disabled_agents": [],
  "disabled_hooks": [],
  "lsp": {},
}
