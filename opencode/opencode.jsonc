{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "oh-my-openagent@3.15.0",
    "opencode-openai-codex-auth@4.4.0",
    "opencode-gemini-auth@latest",
    // "file:///Users/tim/dev/dotfiles/opencode/local-plugins",

    "@plannotator/opencode@latest",

    // "@plannotator/opencode@0.15.5",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@nick-vi/opencode-type-inject@1.3.1",
    "@bastiangx/opencode-unmoji@0.3.11",
    "@tarquinen/opencode-dcp@latest",
    "opencode-wakatime@latest",
    "@whisperopencode/push@latest"
    // "octto",
  ],

  "model": "openai/gpt-5.2",
  "autoupdate": true,
  "share": "disabled",

  "mcp": {
    "mcpproxy": {
      "url": "http://localhost:8080/mcp/",
      "type": "remote",
      "enabled": true,
    },
  },

  "enabled_providers": [
    "openai",
    "zai-coding-plan",
    "opencode-go",
    "omniroute",
    "google",
    // "github-copilot",
  ],

  "lsp": {
    "markdown": {
      "command": ["npx", "-y", "remark-language-server", "--stdio"],
      "extensions": [".md"],
    },
  },

  "provider": {
    "openai": {
      "name": "OpenAI",
      "whitelist": [
        "gpt-5.4",
        "gpt-5.4-mini",
        "gpt-5.3-codex",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.1-codex-max",
        "gpt-5.1-codex-mini",
      ],
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false,
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini (OAuth)",
          "limit": { "context": 400000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium",
            },
          },
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT 5.1 Codex Mini (OAuth)",
          "limit": { "context": 128000, "output": 64000 },
          "modalities": { "input": ["text"], "output": ["text"] },
        },
      },
    },
    "zai-coding-plan": {
      "name": "Zhipu AI",
      "whitelist": [
        "glm-4.7",
        "glm-4.7-flash",
        "glm-4.6v",
        "glm-5",
        "glm-5-turbo",
      ],
      "models": {
        "glm-4.7": {
          "name": "GLM 4.7",
          "limit": { "context": 200000, "output": 128000 },
        },
        "glm-4.7-flash": {
          "name": "GLM 4.7 Flash",
          "limit": { "context": 200000, "output": 128000 },
        },
        "glm-4.6v": {
          "name": "GLM 4.6 Vision",
          "limit": { "context": 128000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
        },
        "glm-5": {
          "name": "GLM 5",
          "limit": { "context": 200000, "output": 128000 },
        },
        "glm-5-turbo": {
          "name": "GLM 5 Turbo",
          "limit": { "context": 200000, "output": 128000 },
        },
      },
    },
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OMNi",
      "options": {
        "baseURL": "https://omniroute.e6ejok.easypanel.host/v1",
        "apiKey": "{env:OMNIROUTE_TOKEN}",
      },
      "models": {
        "reasoning-main": {
          "name": "Reasoning Main",
          "tools": true,
        },
        "reasoning-cheap": {
          "name": "Reasoning Cheap",
          "tools": true,
        },
        "coding-main": {
          "name": "Coding Main",
          "tools": true,
        },
        "coding-cheap": {
          "name": "Coding Cheap",
          "tools": true,
        },
        "deep-premium": {
          "name": "Deep Premium",
          "tools": true,
        },
        "research-fast": {
          "name": "Research Fast",
          "tools": true,
        },
        "quick-free": {
          "name": "Quick Free",
          "tools": true,
        },
        "vision-main": {
          "name": "Vision Main",
          "tools": true,
        },
        "writing-cheap": {
          "name": "Writing Cheap",
          "tools": true,
        },
      },
    },
    "omniroute-raw": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRouteRaw",
      "options": {
        "baseURL": "https://omniroute.e6ejok.easypanel.host/v1",
        "apiKey": "{env:OMNIROUTE_TOKEN}",
      },
      "models": {
        "cx/gpt-5.4": { "name": "GPT 5.4" },
        "cx/gpt-5.3-codex": { "name": "GPT 5.3 Codex" },
        "cx/gpt-5.3-codex-xhigh": { "name": "GPT 5.3 Codex XHigh" },
        "cx/gpt-5.3-codex-high": { "name": "GPT 5.3 Codex High" },
        "cx/gpt-5.3-codex-low": { "name": "GPT 5.3 Codex Low" },
        "cx/gpt-5.3-codex-none": { "name": "GPT 5.3 Codex None" },
        "cx/gpt-5.1-codex-mini": { "name": "GPT 5.1 Codex Mini" },
        "cx/gpt-5.1-codex-mini-high": { "name": "GPT 5.1 Codex Mini High" },
        "cx/gpt-5.2-codex": { "name": "GPT 5.2 Codex" },
        "cx/gpt-5.2": { "name": "GPT 5.2" },
        "cx/gpt-5.1-codex-max": { "name": "GPT 5.1 Codex Max" },
        "cx/gpt-5.1-codex": { "name": "GPT 5.1 Codex" },
        "cx/gpt-5.1": { "name": "GPT 5.1" },
        "cx/gpt-5-codex": { "name": "GPT 5 Codex" },
        "cx/gpt-5-codex-mini": { "name": "GPT 5 Codex Mini" },
        "kr/claude-sonnet-4.5": { "name": "Claude Sonnet 4.5" },
        "kr/claude-haiku-4.5": { "name": "Claude Haiku 4.5" },
        "glm/glm-5.1": { "name": "GLM 5.1" },
        "glm/glm-5": { "name": "GLM 5" },
        "glm/glm-5-turbo": { "name": "GLM 5 Turbo" },
        "glm/glm-4.7-flash": { "name": "GLM 4.7 Flash" },
        "glm/glm-4.7": { "name": "GLM 4.7" },
        "glm/glm-4.6v": { "name": "GLM 4.6V" },
        "glm/glm-4.6": { "name": "GLM 4.6" },
        "glm/glm-4.5v": { "name": "GLM 4.5V" },
        "glm/glm-4.5": { "name": "GLM 4.5" },
        "glm/glm-4.5-air": { "name": "GLM 4.5 Air" },
        "opencode-go/glm-5": { "name": "OpenCode Go GLM 5" },
        "opencode-go/kimi-k2.5": { "name": "OpenCode Go Kimi K2.5" },
        "opencode-go/minimax-m2.7": { "name": "OpenCode Go MiniMax M2.7" },
        "opencode-go/minimax-m2.5": { "name": "OpenCode Go MiniMax M2.5" },
      },
    },
    "google": {
      "name": "Google",
      "whitelist": [
        "gemini-3.1-pro-preview",
        "gemini-3-flash-preview",
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-2.5-flash-lite",
        "antigravity-gemini-3.1-pro",
        "antigravity-gemini-3-flash",
        "antigravity-claude-sonnet-4-6",
        "antigravity-claude-opus-4-6-thinking",
      ],
      "options": {
        "only_defined_models": true,
        "discover": false,
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "limit": { "context": 2000000, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview",
          "limit": { "context": 1000000, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": { "context": 2000000, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "limit": { "context": 1000000, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-2.5-flash-lite": {
          "name": "Gemini 2.5 Flash Lite",
          "limit": { "context": 1000000, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } },
          },
        },
      },
    },
  },
}
