<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openchamber.web</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/tim/.bun/bin/bun</string>
        <string>/Users/tim/.volta/tools/image/packages/@openchamber/web/lib/node_modules/@openchamber/web/server/index.js</string>
        <string>--port</string>
        <string>1911</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/tim</string>

    <key>RunAtLoad</key>
