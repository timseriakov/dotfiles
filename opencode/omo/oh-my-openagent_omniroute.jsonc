{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": { "model": "omniroute/reasoning-main" },
    "oracle": { "model": "omniroute/reasoning-main" },
    "hephaestus": { "model": "omniroute/deep-premium", "variant": "medium" },
    "atlas": { "model": "omniroute/coding-main" },
    "librarian": { "model": "omniroute/research-fast" },
    "explore": { "model": "omniroute/quick-free" },
    "multimodal-looker": { "model": "omniroute/reasoning-cheap" },
    "plan": {
      "model": "omniroute/reasoning-main",
      "prompt_append": "Всегда пиши план на русском языке. (Always write the plan in Russian.)",
    },
    "prometheus": {
      "model": "omniroute/reasoning-main",
      "prompt_append": "Всегда пиши план на русском языке. (Always write the plan in Russian.)",
    },
    "metis": { "model": "omniroute/deep-premium" },
    "momus": { "model": "omniroute/deep-premium" },
    "sisyphus-junior": { "model": "omniroute/coding-cheap" },
    "OpenCode-Builder": { "model": "omniroute/coding-main" },
  },
  "categories": {
    "deep": { "model": "omniroute/deep-premium" },
    "quick": { "model": "omniroute/quick-free" },
    "writing": { "model": "omniroute/writing-cheap" },
    "visual-engineering": { "model": "omniroute/reasoning-cheap" },
    "ultrabrain": { "model": "omniroute/reasoning-main" },
    "unspecified-low": { "model": "omniroute/coding-cheap" },
    "unspecified-high": { "model": "omniroute/reasoning-main" },
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "omniroute": 5,
    },
    "modelConcurrency": {
      "omniroute/quick-free": 10,
      "omniroute/coding-cheap": 8,
      "omniroute/coding-main": 4,
      "omniroute/reasoning-cheap": 6,
      "omniroute/reasoning-main": 3,
      "omniroute/deep-premium": 2,
      "omniroute/research-fast": 8,
      "omniroute/writing-cheap": 6,
    },
  },
}
