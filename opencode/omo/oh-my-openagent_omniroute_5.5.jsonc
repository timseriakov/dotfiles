      "model": "omniroute/reasoning-main",
      "fallback_models": ["omniroute/deep-premium", "omniroute/coding-main"],
      "prompt_append": "# MCP: playwriter vs playwright\n\n`playwriter` — MCP-сервер для браузерной автоматизации в этой конфигурации; `playwright` — фреймворк, не имя MCP. Не подменяй `playwriter` на `playwright` и не запускай Playwright без явной просьбы.",
    },
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 401, 403, 404, 429, 500, 502, 503, 504],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 15,
    "timeout_seconds": 10,
    "notify_on_fallback": true,
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "omniroute": 5,
    },
    "modelConcurrency": {
      "omniroute/quick-free": 5,
      "omniroute/coding-cheap": 4,
      "omniroute/coding-main": 2,
      "omniroute/reasoning-cheap": 3,
      "omniroute/reasoning-main": 2,
      "omniroute/deep-premium": 1,
      "omniroute/research-fast": 4,
      "omniroute/writing-cheap": 3,
    },
  },
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": false,
    "agents": true,
    "hooks": true,
    "plugins": false,
    "plugins_override": {},
  },
  "disabled_mcps": ["playwright"],
  "disabled_skills": ["playwright"],
  "disabled_agents": [],
  "disabled_hooks": [],
  "lsp": {
    "markdown": {
      "command": ["npx", "-y", "remark-language-server", "--stdio"],
      "extensions": [".md"],
    },
  },
}
