  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": true,
    "agents": true,
    "hooks": true,
    "plugins": true,
    "plugins_override": {},
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": true,
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": false,
      "notification": "off",
      "turn_protection": {
        "enabled": true,
        "turns": 3,
      },
    },
