{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
      "prompt_append": "## BEADS-FIRST EXECUTION\nBeads Rust (`br`) is the authoritative runtime state for non-trivial work in repositories that use this profile. Markdown plan checkboxes are a compatibility mirror only. Never treat checked markdown boxes as proof of completion or as the source of truth for what to do next.\n\nWhen execution is plan-driven or multi-step, prefer Beads state for runtime decisions:\n- read current work from `br ready --json`, `br list --json`, or `br show <id> --json` as appropriate\n- use Beads status transitions as the real ledger of `open`, `in_progress`, blocked, and complete\n- if markdown and Beads disagree, Beads wins\n- update markdown only as a mirror/compatibility surface after the Beads state is correct\n\nAssume `br` is installed and intended to be authoritative in the working repo. Do not silently fall back to markdown-only state management.",
    },
    "atlas": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.1,
      "prompt_append": "## BEADS RUST EXECUTION PROTOCOL\\n\\n`br` CLI is the authoritative task ledger. Markdown plan checkboxes are a **read-only display mirror** — never the source of truth for completion.\\n\\n### HOOK REDIRECT RULE\\nYou WILL receive injected system-reminders about markdown checkboxes (COMPLETION GATE, BOULDER STATE, BOULDER CONTINUATION). These are compatibility artifacts from the plan display layer. When you see them:\\n1. Execute the `br` equivalent FIRST\\n2. THEN mirror the checkbox only if needed for display compatibility\\n3. NEVER use checkbox state as proof of completion — `br list --json` is ground truth\\n\\n### SESSION CYCLE\\nbr init → br ready --json → br show <id> --json → br update <id> --claim → work → verify → br close <id> --reason \"Completed\" → br sync --flush-only\\n\\n### DECISION TEST\\n- Trivial (< 2 min, 1 file, 1-line change): skip `br`, just do it\\n- Non-trivial: create/claim a `br` issue FIRST, then work\\n\\n### ATLAS TRIGGERS\\n- WHEN resuming a boulder session: `br ready --json` to find next claimable task — NOT \"read plan and find next `- [ ]`\"\\n- WHEN delegating to subagent: `br update <id> --claim` → include issue ID in task() prompt\\n- WHEN subagent completes: run verification phases → `br close <id> --reason \"Completed\" --suggest-next --json` → THEN mirror checkbox\\n- WHEN COMPLETION GATE fires: `br close <id>` is the real closeout; checkbox mirror is secondary\\n- WHEN BOULDER CONTINUATION fires: `br ready --json` for next task; ignore \"mark `- [x]` immediately\" — close via `br` instead\\n- WHEN ORCHESTRATOR REMINDER says \"count checkboxes\": STOP → `br list --json` instead — that is YOUR ground truth\\n- WHEN all tasks done: `br sync --flush-only",
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
    },
    "librarian": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1,
    },
    "explore": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1,
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "prompt_append": "## BEADS-FIRST TASK EXECUTION\nBeads Rust (`br`) is the authoritative runtime ledger. Markdown plan checkboxes are only a compatibility mirror.\n\nWhen you execute a non-trivial assigned task:\n- use the Beads issue/context as the real task state when available\n- do not claim a task is complete just because markdown is checked\n- if you touch markdown, treat it as a mirror after the real execution state is correct in Beads\n- if Beads and markdown disagree, report the drift and follow Beads\n\nAssume `br` is available in repositories using this profile.",
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.1,
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "temperature": 0.2,
      "prompt_append": "Всегда пиши план на русском языке. (Always write the plan in Russian.)",
    },
    "OpenCode-Builder": {
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.05,
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "temperature": 0.2,
      "prompt_append": "Всегда пиши план на русском языке. (Always write the plan in Russian.)\\n\\n## BEADS RUST EXECUTION PROTOCOL\\n\\n`br` CLI is the authoritative task ledger. Markdown plan checkboxes are a **read-only display mirror** — never the source of truth for completion.\\n\\n### HOOK REDIRECT RULE\\nYou WILL receive injected system-reminders about markdown checkboxes (COMPLETION GATE, BOULDER STATE, BOULDER CONTINUATION). These are compatibility artifacts from the plan display layer. When you see them:\\n1. Execute the `br` equivalent FIRST\\n2. THEN mirror the checkbox only if needed for display compatibility\\n3. NEVER use checkbox state as proof of completion — `br list --json` is ground truth\\n\\n### SESSION CYCLE\\nbr init → br ready --json → br show <id> --json → br update <id> --claim → work → verify → br close <id> --reason \"Completed\" → br sync --flush-only\\n\\n### DECISION TEST\\n- Trivial (< 2 min, 1 file, 1-line change): skip `br`, just do it\\n- Non-trivial: create/claim a `br` issue FIRST, then work\\n\\n### PROMETHEUS TRIGGERS\\n- WHEN creating a plan: structure each task so it maps cleanly to a `br` work item (clear title, type, priority, description, acceptance criteria)\\n- WHEN plan is approved: `br create --title \"...\" --type <type> --priority <P0-P4> --description \"...\"` for each task in order\\n- WHEN plan has dependencies: create blocked issues and let `br` track the dependency graph",
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "temperature": 0.2,
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "temperature": 0.1,
    },
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true,
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100,
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "openai": 5,
    },
    "modelConcurrency": {
      "openai/gpt-5.4": 1,
      "openai/gpt-5.4-mini": 6,
      "openai/gpt-5.3-codex": 3,
      "openai/gpt-5.1-codex-mini": 10,
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.7,
      "prompt_append": "Focus on modern aesthetics, responsiveness, and clean CSS/Tailwind.",
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "temperature": 0.15,
      "prompt_append": "For architecture tasks, use $likec4-architecture. Prefer LikeC4 DSL changes, validate with `npx likec4 validate`, and return preview/build/export commands.",
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "prompt_append": "Focus on robustness, error handling, and type safety.",
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.3,
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.3,
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.15,
    },
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "temperature": 0.3,
    },
  },
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": true,
    "agents": true,
    "hooks": true,
    "plugins": true,
    "plugins_override": {},
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "experimental": {
    "auto_resume": true,
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": true,
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": false,
      "notification": "off",
      "turn_protection": {
        "enabled": true,
        "turns": 3,
      },
    },
  },
  "disabled_mcps": [],
  "disabled_skills": ["playwright"],
  "disabled_agents": [],
  "disabled_hooks": [],
  "google_auth": false,
  "lsp": {},
}
