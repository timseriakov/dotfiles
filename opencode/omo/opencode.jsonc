{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@4.0.0"],
  "instructions": ["~/dev/dotfiles/opencode/omo/instructions/mcp-naming.md"],
  "provider": {
    "omniroute": {
      "models": {
        "reasoning-main": {
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "capabilities": { "vision": true, "attachment": true }
        },
        "reasoning-cheap": {
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "capabilities": { "vision": true, "attachment": true }
        }
      }
    }
  }
}
