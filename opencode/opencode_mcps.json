{
  "mcp": {
    "mcpproxy": {
      "url": "http://localhost:8080/mcp/",
      "type": "remote",
      "enabled": true
    },
    "vercel": {
      "url": "https://mcp.vercel.com",
      "type": "remote",
      "enabled": false
    },
    "playwriter": {
      "command": ["npx", "-y", "playwriter@latest"],
      "type": "local",
      "enabled": false
    },
    "engram": {
      "command": ["engram", "mcp"],
      "type": "local",
      "enabled": false
    },
    "frame0": {
      "command": ["npx", "-y", "frame0-mcp-server"],
      "type": "local",
      "enabled": false
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "type": "local",
      "enabled": false
    },
    "grepai": {
      "command": ["grepai", "mcp-serve"],
      "type": "local",
      "enabled": false
    }
  }
}
