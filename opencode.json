{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "command": ["engram", "mcp"],
      "type": "local",
      "enabled": true
    }
  },
  "lsp": {
    "remark": {
      "command": ["npx", "-y", "remark-language-server", "--stdio"],
      "extensions": [".md"]
    }
  }
}
