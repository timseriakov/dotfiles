#!/bin/bash

set -euo pipefail

# Ensure Homebrew and system binaries are available from GUI-launched qutebrowser.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"

die() {
  echo "summarize-url: $*" >&2
  exit 1
}

choose_tmux_session() {
  local env_target="$1"
  local clients_out="$2"
  local fallback="$3"

  if [[ -n "$env_target" ]]; then
    printf '%s\n' "$env_target"
    return 0
  fi

  local best_activity=""
  local best_session=""
  local line activity session

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    activity="${line%% *}"
    session="${line#* }"
    [[ "$activity" == "$line" ]] && continue
    [[ "$activity" =~ ^[0-9]+$ ]] || continue
    if [[ -z "$best_activity" ]]; then
      best_activity="$activity"
      best_session="$session"
      continue
    fi
    if (( activity > best_activity )); then
      best_activity="$activity"
      best_session="$session"
    elif (( activity == best_activity )); then
      if [[ "$session" < "$best_session" ]]; then
        best_session="$session"
      fi
    fi
  done <<<"$clients_out"

  if [[ -n "$best_session" ]]; then
    printf '%s\n' "$best_session"
  else
    printf '%s\n' "$fallback"
  fi
}

ensure_tmux_session() {
  local session="$1"
  tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -s "$session"
}

find_target_window_id() {
  local session="$1"
  local target_name="$2"
  local windows_out line window_id rest marker window_name
  local fallback_id=""

  windows_out="$(tmux list-windows -t "$session" -F "#{window_id} #{@qute_summarize_window} #{window_name}" 2>/dev/null || true)"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    window_id="${line%% *}"
    rest="${line#* }"
    marker="${rest%% *}"
    window_name="${rest#* }"
    if [[ "$marker" == "1" ]]; then
      printf '%s\n' "$window_id"
      return 0
    fi
    if [[ -z "$fallback_id" && "$window_name" == "$target_name" ]]; then
      fallback_id="$window_id"
    fi
  done <<<"$windows_out"
  [[ -n "$fallback_id" ]] && printf '%s\n' "$fallback_id"
}

resolve_script_path() {
  if command -v python3 >/dev/null 2>&1; then
    python3 -c "import os, sys; print(os.path.realpath(sys.argv[1]))" "$0"
    return 0
  fi
  realpath "$0"
}

resolve_shared_entrypoint() {
  local script_dir
  script_dir="$(cd "$(dirname "$(resolve_script_path)")" && pwd)"
  local target="$script_dir/../../bin/sum-analyze"
  python3 -c "import os, sys; print(os.path.realpath(sys.argv[1]))" "$target"
}

make_shell_launcher() {
  local launcher
  launcher="$(mktemp /tmp/qute-summarize-shell.XXXXXX)"
  cat >"$launcher" <<'EOF'
#!/bin/bash
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
rm -f -- "$0" >/dev/null 2>&1 || true
if command -v fish >/dev/null 2>&1; then
  if [[ -n "${QUTE_READY_KEY:-}" ]]; then
    exec fish -ilC 'function __qute_ready --on-event fish_prompt; tmux wait-for -S "$QUTE_READY_KEY"; functions -e __qute_ready; end'
  fi
  exec fish -il
fi
if [[ -n "${SHELL:-}" ]]; then
  exec "$SHELL" -il
fi
exec /bin/bash -il
EOF
  chmod +x "$launcher"
  printf '%s\n' "$launcher"
}

wait_for_pane_command() {
  local pane_id="$1"
  local expected_cmd="$2"
  local max_attempts="${3:-60}"
  local sleep_seconds="${4:-0.05}"
  for ((attempt = 0; attempt < max_attempts; attempt++)); do
    local current_cmd
    current_cmd="$(tmux display-message -p -t "$pane_id" "#{pane_current_command}" 2>/dev/null || true)"
    if [[ "$current_cmd" == "$expected_cmd" ]]; then return 0; fi
    sleep "$sleep_seconds"
  done
  return 1
}

wait_for_prompt_redraw() {
  sleep "${1:-0.08}"
}

main() {
  local dry_run="0"
  local quality_mode="0"
  local analyze_mode=""
  local url=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --quality) quality_mode="1" ;;
      --analyze-quick) analyze_mode="quick" ;;
      --analyze-deep) analyze_mode="deep" ;;
      --dry-run) dry_run="1" ;;
      --self-test) exit 0 ;;
      *) url="$1" ;;
    esac
    shift
  done

  [[ -z "$url" ]] && die "missing URL"
  command -v tmux >/dev/null 2>&1 || die "tmux not found"

  local clients_out=""
  [[ -z "${SUMMARIZE_TMUX_TARGET:-}" ]] && clients_out="$(tmux list-clients -F "#{client_activity} #{client_session}" 2>/dev/null || true)"

  local session
  session="$(choose_tmux_session "${SUMMARIZE_TMUX_TARGET:-}" "$clients_out" "summarize")"
  
  local shared_abs
  shared_abs="$(resolve_shared_entrypoint)"
  
  local mode="summary"
  [[ "$quality_mode" == "1" ]] && mode="quality-summary"
  [[ "$analyze_mode" == "quick" ]] && mode="quick"
  [[ "$analyze_mode" == "deep" ]] && mode="deep"

  local summarize_cmd
  summarize_cmd="$(resolve_shared_entrypoint) --mcat $mode '$url'"

  local existing_window_id
  existing_window_id="$(find_target_window_id "$session" "summarize")"

  if [[ "$dry_run" == "1" ]]; then
    echo "session=$session"
    echo "url=$url"
    echo "command=$summarize_cmd"
    exit 0
  fi

  ensure_tmux_session "$session"
  
  local window_id pane_id window_created="0"
  if [[ -n "$existing_window_id" ]]; then
    window_id="$existing_window_id"
    pane_id="$(tmux display-message -p -t "$window_id" "#{pane_id}" 2>/dev/null || true)"
  else
    window_created="1"
    local ready_key="qute-summarize-ready-$$-$RANDOM"
    local launcher_cmd
    launcher_cmd="$(make_shell_launcher)"
    window_id="$(tmux new-window -P -F "#{window_id}" -t "$session" -n "summarize" -c "$HOME" -e "QUTE_READY_KEY=$ready_key" "$launcher_cmd")"
    tmux wait-for "$ready_key"
    tmux set-window-option -q -t "$window_id" @qute_summarize_window 1 || true
    pane_id="$(tmux display-message -p -t "$window_id" "#{pane_id}" 2>/dev/null || true)"
  fi

  [[ -z "$pane_id" ]] && die "failed to resolve target pane"

  if ! wait_for_pane_command "$pane_id" "fish"; then
    tmux send-keys -t "$pane_id" "fish" Enter
    wait_for_pane_command "$pane_id" "fish" || die "failed to start fish"
  fi
  [[ "$window_created" == "1" ]] && wait_for_prompt_redraw 0.05

  tmux send-keys -t "$pane_id" C-u
  tmux set-buffer -- "$summarize_cmd"
  tmux paste-buffer -d -t "$pane_id"
  wait_for_prompt_redraw
  tmux send-keys -t "$pane_id" Enter
  tmux select-window -t "$window_id" >/dev/null 2>&1 || true
}

main "$@"
