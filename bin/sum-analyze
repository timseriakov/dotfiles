#!/usr/bin/env bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"

usage() {
  cat >&2 <<'EOF'
Usage:
  sum-analyze [--mcat] quick <url>
  sum-analyze [--mcat] deep <url>
  sum-analyze [--mcat-inline] quick <url>
  sum-analyze [--mcat-inline] deep <url>
EOF
}

die() {
  echo "sum-analyze: $*" >&2
  exit 1
}

sanitize_url() {
  local url="$1"

  if ! command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "$url"
    return 0
  fi

  python3 - <<'PY' "$url"
import sys
import urllib.parse

raw = sys.argv[1]
parsed = urllib.parse.urlsplit(raw)
query_pairs = urllib.parse.parse_qsl(parsed.query, keep_blank_values=True)
filtered = [(k, v) for (k, v) in query_pairs if not k.lower().startswith("utm_")]
new_query = urllib.parse.urlencode(filtered, doseq=True)
cleaned = urllib.parse.urlunsplit((parsed.scheme, parsed.netloc, parsed.path, new_query, parsed.fragment))
print(cleaned)
PY
}

prompt_template_path() {
  local mode="$1"
  local repo_root
  repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

  if [[ "$mode" == "deep" ]]; then
    printf '%s\n' "$repo_root/qutebrowser/prompts/summarize-analyze-deep.txt"
  else
    printf '%s\n' "$repo_root/qutebrowser/prompts/summarize-analyze-quick.txt"
  fi
}

extract_markdown() {
  local url="$1"
  summarize "$url" --extract --format md --plain 2> >(grep -v '^Decompression error: ZlibError$' >&2)
}

prepare_mcat_render() {
  if ! command -v python3 >/dev/null 2>&1; then
    cat
    return 0
  fi

  python3 - <<'PY'
import sys

lines = sys.stdin.read().splitlines()
if len(lines) >= 3 and lines[0] == '---':
    end = None
    for i in range(1, len(lines)):
        if lines[i] == '---':
            end = i
            break
    if end is not None:
        frontmatter = lines[1:end]
        body = lines[end + 1:]
        print('## Metadata')
        print()
        for line in frontmatter:
            if ':' in line:
                key, value = line.split(':', 1)
                print(f'- **{key.strip()}**: {value.strip()}')
            elif line.strip():
                print(f'- {line.strip()}')
        print()
        print('\n'.join(body))
        sys.exit(0)

print('\n'.join(lines))
PY
}

render_output() {
  local render_mode="$1"

  if [[ "$render_mode" == "inline" ]]; then
    command -v mcat >/dev/null 2>&1 || die "mcat not found"
    local temp_output_base temp_output temp_render
    temp_output_base="$(mktemp /tmp/sum-analyze-output.XXXXXX)"
    temp_output="$temp_output_base.md"
    temp_render="$temp_output_base.render.md"
    tee "$temp_output"
    printf '\n'
    prepare_mcat_render < "$temp_output" > "$temp_render"
    cat "$temp_render" | mcat -P -t nord --output md
    rm -f "$temp_output" "$temp_render"
    return 0
  fi

  if [[ "$render_mode" == "pager" ]]; then
    command -v mcat >/dev/null 2>&1 || die "mcat not found"
    local temp_output
    temp_output="$(mktemp /tmp/sum-analyze-output.XXXXXX)"
    tee "$temp_output"
    printf '\n'
    prepare_mcat_render < "$temp_output" | mcat -p -t nord --output md
    rm -f "$temp_output"
    return 0
  fi

  cat
}

main() {
  local render_mode="plain"
  if [[ "${1:-}" == "--mcat" ]]; then
    render_mode="pager"
    shift
  fi
  if [[ "${1:-}" == "--mcat-inline" ]]; then
    render_mode="inline"
    shift
  fi

  local mode="${1:-}"
  local url="${2:-}"

  if [[ "$mode" != "quick" && "$mode" != "deep" ]]; then
    usage
    exit 2
  fi
  if [[ -z "$url" ]]; then
    usage
    exit 2
  fi

  command -v summarize >/dev/null 2>&1 || die "summarize not found"

  local sanitized
  sanitized="$(sanitize_url "$url")"

  local prompt_template
  prompt_template="$(prompt_template_path "$mode")"
  [[ -f "$prompt_template" ]] || die "prompt template not found: $prompt_template"

  local analyzed_at
  analyzed_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  local prompt_runtime
  prompt_runtime="$(mktemp /tmp/sum-analyze-prompt.XXXXXX)"
  {
    printf 'source_url: %s\n' "$sanitized"
    printf 'analyzed_at: %s\n' "$analyzed_at"
    printf 'mode: %s\n' "$mode"
    printf '\n'
    cat "$prompt_template"
  } >"$prompt_runtime"

  local length_arg="medium"
  if [[ "$mode" == "deep" ]]; then
    length_arg="xxl"
    extract_markdown "$sanitized" | summarize - --plain --prompt-file "$prompt_runtime" --length "$length_arg" --model quality | render_output "$render_mode"
    exit 0
  fi

  extract_markdown "$sanitized" | summarize - --plain --prompt-file "$prompt_runtime" --length "$length_arg" | render_output "$render_mode"
}

main "$@"
